{
  "name": "vophuthinh-portfolio",
  "version": "2.0.0",
  "description": "AI Engineer Portfolio Website - Modern, responsive, and PWA-enabled",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run inject-nonce",
    "preview": "vite preview",
    "serve": "node server.js",
    "serve:prod": "node server.js",
    "images": "node scripts/generate-responsive-images.js",
    "optimize:css": "node scripts/optimize-css.js",
    "inject-nonce": "node scripts/inject-nonce.js",
    "lint:js": "eslint js/**/*.js",
    "lint:css": "stylelint assets/css/**/*.css",
    "format": "prettier --write \"**/*.{js,css,html,json,md}\"",
    "lighthouse": "lighthouse http://localhost:3000 --view",
    "test:lighthouse": "lighthouse http://localhost:3000 --output=json --output-path=./lighthouse-report.json",
    "analyze": "vite-bundle-visualizer",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "portfolio",
    "ai-engineer",
    "ml-engineer",
    "pwa",
    "responsive",
    "vanilla-js",
    "vite"
  ],
  "author": "Vo Phu Thinh <vophuthinhcm@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vophuthinh/Portfolio.git"
  },
  "homepage": "https://vophuthinh.com",
  "devDependencies": {
    "eslint": "^8.56.0",
    "lighthouse": "^13.2.0",
    "prettier": "^3.1.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.33.5",
    "stylelint": "^16.1.0",
    "terser": "^5.26.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
